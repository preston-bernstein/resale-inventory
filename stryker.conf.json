{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "packageManager": "npm",
  "testRunner": "vitest",
  "plugins": ["@stryker-mutator/vitest-runner"],
  "reporters": ["clear-text", "progress", "html"],
  "mutate": [
    "lib/transitions.ts",
    "lib/money.ts",
    "lib/clothing.ts",
    "lib/electronics.ts",
    "lib/isbn.ts",
    "lib/constants.ts",
    "lib/dashboard.ts",
    "lib/photos.ts",
    "lib/imageOptimize.ts",
    "lib/tourStateMachine.ts",
    "lib/tourSteps.ts",
    "lib/useReducedMotion.ts",
    "lib/pairingToken.ts",
    "lib/tailnetOrigin.ts",
    "lib/apiRequest.ts",
    "lib/tenantAuth.ts",
    "lib/credentialCrypto.ts",
    "lib/connections.ts",
    "lib/consent.ts",
    "lib/automationGate.ts",
    "lib/brands.ts",
    "lib/forwardAuth.ts",
    "middleware.ts",
    "app/api/**/*.ts"
  ],
  "coverageAnalysis": "perTest",
  "timeoutMS": 120000,
  "vitest": {
    "configFile": "vitest.config.ts"
  },
  "thresholds": {
    "high": 90,
    "low": 80,
    "break": 75
  }
}
