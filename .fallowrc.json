{
  // This file is JSONC: fallow reads these comments; generic JSON tools may not.
  "$schema": "https://raw.githubusercontent.com/fallow-rs/fallow/main/schema.json",
  // Next.js App Router entry-point conventions — not src/index.ts, the
  // framework itself owns the entry points via these file-name conventions.
  "entry": [
    "app/**/page.{ts,tsx}",
    "app/**/layout.{ts,tsx}",
    "app/**/route.{ts,tsx}",
    "middleware.ts",
    "next.config.ts"
  ],
  // Verified false positive, not a suppression of a real problem: all 8
  // marketplace connector modules (ebay/etsy/amazon/poshmark/depop/mercari/
  // vinted/grailed) deliberately implement the same Connector interface --
  // createListing/updateListing/markSold/delist/checkConnectionHealth, with
  // platform-specific bodies -- and assemble them into a single
  // <platform>Connector object, which is the file's real public surface
  // (lib/connectors/registry.ts imports only the assembled objects, never
  // a raw method by name). The raw functions stay individually exported
  // only because each connector's own lib/connectors/__tests__/<platform>.
  // test.ts unit-tests them directly by name rather than through the
  // assembled object; de-exporting any of them breaks that test file's
  // design (root fix attempted first, see grep evidence below). Checked via
  // grep across lib/connectors/ (both connector files and __tests__): no
  // file other than a connector's own module and its own test file imports
  // any of these 5 names. Confirmed 2026-07-16.
  "ignoreExports": [
    { "file": "lib/connectors/ebay.ts", "exports": ["createListing", "updateListing", "markSold", "delist", "checkConnectionHealth"] },
    { "file": "lib/connectors/etsy.ts", "exports": ["createListing", "updateListing", "markSold", "delist", "checkConnectionHealth"] },
    { "file": "lib/connectors/amazon.ts", "exports": ["createListing", "updateListing", "markSold", "delist", "checkConnectionHealth"] },
    { "file": "lib/connectors/poshmark.ts", "exports": ["createListing", "updateListing", "markSold", "delist", "checkConnectionHealth"] },
    { "file": "lib/connectors/depop.ts", "exports": ["createListing", "updateListing", "markSold", "delist", "checkConnectionHealth"] },
    { "file": "lib/connectors/mercari.ts", "exports": ["createListing", "updateListing", "markSold", "delist", "checkConnectionHealth"] },
    { "file": "lib/connectors/vinted.ts", "exports": ["createListing", "updateListing", "markSold", "delist", "checkConnectionHealth"] },
    { "file": "lib/connectors/grailed.ts", "exports": ["createListing", "updateListing", "markSold", "delist", "checkConnectionHealth"] }
  ],
  "duplicates": {
    // Report every duplicate pair, not just widespread copy-paste — the
    // project's own standing instruction is strict thresholds everywhere.
    "minOccurrences": 2
  },
  // Accepted (not suppressed — fallow has no per-clone-fingerprint ignore,
  // only file-glob ignores, which would hide real future duplication in
  // these same files too broadly to use here): app/api/items/[id]/phone-session/route.ts
  // POST and app/api/items/[id]/photos/route.ts POST still share a ~10-line
  // clone (Next.js route-handler signature + the shared lib/apiRequest.ts
  // parseItemId() call). The real duplication behind it was extracted into
  // lib/apiRequest.ts; what remains is the framework-mandated handler
  // signature every exported HTTP-method function must repeat, which a
  // higher-order wrapper could hide but not actually eliminate — judged not
  // worth trading directness for. Confirmed 2026-07-12.
  // Verified false positive, not a suppression of a real problem: only
  // referenced via the dynamic string `compat.extends('next/typescript')`
  // in eslint.config.mjs, which static analysis can't trace through — ESLint
  // genuinely fails without it. Confirmed 2026-07-11.
  "ignoreDependencies": ["eslint-config-next"],
  "rules": {
    "unused-dependencies": "error",
    // Verified false positive: tailwindcss is referenced only from
    // app/globals.css (`@import "tailwindcss"`), which Next.js compiles away
    // at build time via @tailwindcss/postcss — there is no runtime import,
    // so devDependencies is the correct place for it, not dependencies.
    // Confirmed 2026-07-11.
    "dev-dependencies-in-production": "off"
  }
}
